<!--
 HyperCore v3.0 — GamePowerOptFeature.xml
 Changes from v2.1:
   - Removed Genshin Impact from IgnoredApps on cliffs (was excluded from optimization!)
   - Kept aggressive FPS thresholds and PID tuning from v2.1
   - Kept jank rescue enabled
-->
<Feature>
   <Name>GamePowerOptFeature</Name>
   <Libname>libgamepoweroptfeature.so</Libname>
   <Configs target = "cliffs">
        <FPS_30_THRESHOLD>0.1, 0.3, 0.1, 0.0</FPS_30_THRESHOLD>
        <FPS_35_THRESHOLD>0.1, 0.3, 0.1, 0.0</FPS_35_THRESHOLD>
        <FPS_40_THRESHOLD>0.1, 0.3, 0.1, 0.0</FPS_40_THRESHOLD>
        <FPS_60_THRESHOLD>0.1, 0.5, 0.1, 0.0</FPS_60_THRESHOLD>
        <FPS_90_THRESHOLD>0.5, 1.0, 0.2, 0.0</FPS_90_THRESHOLD>
        <FPS_120_THRESHOLD>0.5, 1.0, 0.2, 0.0</FPS_120_THRESHOLD>
        <FPS_144_THRESHOLD>0.5, 1.0, 0.2, 0.0</FPS_144_THRESHOLD>
        <FPS_MAX_THRESHOLD>144</FPS_MAX_THRESHOLD>
        <PID_Parameters_Up>10, 2, 5, 30, 300, 0.3</PID_Parameters_Up>
        <PID_Parameters_Down>10, 2, 5, 30, 300, 0.3</PID_Parameters_Down>
        <SAMPLE_CALL_INTERVAL_MSEC>250</SAMPLE_CALL_INTERVAL_MSEC>
        <MAX_SAMPLE_NUM>10</MAX_SAMPLE_NUM>
        <FPS_STABLE_CNT>20</FPS_STABLE_CNT>
        <Freq_Drop_Bottom_ThresholdRatio>10</Freq_Drop_Bottom_ThresholdRatio>
        <MIN_MAX_CAP_RANGE_DOWN>1</MIN_MAX_CAP_RANGE_DOWN>
        <MIN_MAX_CAP_RANGE_UP>1</MIN_MAX_CAP_RANGE_UP>
        <Algo_Engine>Algo_PID</Algo_Engine>
        <!-- HYPERCORE v3.0: Enable jank rescue on cliffs too -->
        <JANKRESCUE_ENABLE>1</JANKRESCUE_ENABLE>
        <JANKRESCUE_LOG_ENABLE>0</JANKRESCUE_LOG_ENABLE>
        <JANKRESCUE_TRACE_ENABLE>0</JANKRESCUE_TRACE_ENABLE>
        <JANK_WORKLOAD_ZONE_FACTOR>20</JANK_WORKLOAD_ZONE_FACTOR>
        <JANK_FILTERING_COEFFICIENT>30</JANK_FILTERING_COEFFICIENT>
        <JANK_SET_THRESHOLD>1</JANK_SET_THRESHOLD>
        <JANK_RESET_THRESHOLD>-1</JANK_RESET_THRESHOLD>
        <TPLOAD_LIGHT_THRESHOLD>0</TPLOAD_LIGHT_THRESHOLD>
    </Configs>
   <Configs>
        <FPS_30_THRESHOLD>0.1, 0.3, 0.1, 0.0</FPS_30_THRESHOLD>
        <FPS_35_THRESHOLD>0.1, 0.3, 0.1, 0.0</FPS_35_THRESHOLD>
        <FPS_40_THRESHOLD>0.1, 0.3, 0.1, 0.0</FPS_40_THRESHOLD>
        <FPS_60_THRESHOLD>0.1, 0.5, 0.1, 0.0</FPS_60_THRESHOLD>
        <FPS_90_THRESHOLD>0.5, 1.0, 0.2, 0.0</FPS_90_THRESHOLD>
        <FPS_120_THRESHOLD>0.5, 1.0, 0.2, 0.0</FPS_120_THRESHOLD>
        <FPS_144_THRESHOLD>0.5, 1.0, 0.2, 0.0</FPS_144_THRESHOLD>
        <FPS_MAX_THRESHOLD>144</FPS_MAX_THRESHOLD>
        <PID_Parameters_Up>10, 2, 5, 30, 300, 0.3</PID_Parameters_Up>
        <PID_Parameters_Down>10, 2, 5, 30, 300, 0.3</PID_Parameters_Down>
        <SAMPLE_CALL_INTERVAL_MSEC>250</SAMPLE_CALL_INTERVAL_MSEC>
        <MAX_SAMPLE_NUM>10</MAX_SAMPLE_NUM>
        <FPS_STABLE_CNT>20</FPS_STABLE_CNT>
        <Freq_Drop_Bottom_ThresholdRatio>10</Freq_Drop_Bottom_ThresholdRatio>
        <MIN_MAX_CAP_RANGE_DOWN>1</MIN_MAX_CAP_RANGE_DOWN>
        <MIN_MAX_CAP_RANGE_UP>1</MIN_MAX_CAP_RANGE_UP>
        <Algo_Engine>Algo_PID</Algo_Engine>
        <JANKRESCUE_ENABLE>1</JANKRESCUE_ENABLE>
        <JANKRESCUE_LOG_ENABLE>0</JANKRESCUE_LOG_ENABLE>
        <JANKRESCUE_TRACE_ENABLE>0</JANKRESCUE_TRACE_ENABLE>
        <JANK_WORKLOAD_ZONE_FACTOR>20</JANK_WORKLOAD_ZONE_FACTOR>
        <JANK_FILTERING_COEFFICIENT>30</JANK_FILTERING_COEFFICIENT>
        <JANK_SET_THRESHOLD>1</JANK_SET_THRESHOLD>
        <JANK_RESET_THRESHOLD>-1</JANK_RESET_THRESHOLD>
        <TPLOAD_LIGHT_THRESHOLD>0</TPLOAD_LIGHT_THRESHOLD>
